# CleanPlated Environment Variables
# Copy this file to .env and fill in your values

# Google Maps API Key (required for map functionality)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Make sure to enable the Maps JavaScript API and configure restrictions
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Analytics (optional)
GA_MEASUREMENT_ID=your_ga_measurement_id

# Data Source API Keys (optional, for ingestion)
CLEANPLATED_SD_SOCRATA_APP_TOKEN=your_socrata_app_token
CLEANPLATED_OC_CPRA_EXPORT_URL=your_oc_cpra_export_url
CLEANPLATED_PASADENA_CPRA_EXPORT_URL=your_pasadena_cpra_export_url